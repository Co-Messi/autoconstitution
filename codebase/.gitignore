# =============================================================================
# autoconstitution .gitignore
# Comprehensive ignore patterns for the autoconstitution Python codebase
# =============================================================================

# =============================================================================
# PYTHON PATTERNS
# =============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
*.whl
pip-wheel-metadata/
*.manifest
*.spec

# Virtual environments
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/
.python-version

# Pip dependency files
pip-log.txt
pip-delete-this-directory.txt

# Installer logs
*.log

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Django / Flask stuff
*.db
*.sqlite3
*.sqlite
instance/
.webassets-cache

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb_checkpoints/

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# Celery
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.env.local
.env.*.local
!.env.example

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# Cython debug symbols
cython_debug/

# Pydantic
.pydantic/

# =============================================================================
# MACHINE LEARNING PATTERNS
# =============================================================================

# Model artifacts
models/
*.pt
*.pth
*.ckpt
*.safetensors
*.h5
*.hdf5
*.onnx
*.tflite
*.pb
*.pbtxt
*.saved_model/
saved_models/
checkpoints/
checkpoint/
runs/
outputs/

# Training artifacts
logs/
log/
tensorboard/
wandb/
mlruns/
lightning_logs/

# Dataset directories
data/
datasets/
raw_data/
processed_data/
*.csv
*.tsv
*.jsonl
*.parquet
*.feather
*.pkl
*.pickle
*.npy
*.npz

# Large binary files
*.bin
*.blob
*.weights

# MLflow
mlartifacts/

# Weights & Biases
wandb/

# Hugging Face
.huggingface/
tokenizers/

# Model cache
.cache/
pretrained/
pretrained_models/

# Experiment tracking
experiments/
experiment_logs/

# =============================================================================
# SWARM RESEARCH SPECIFIC PATTERNS
# =============================================================================

# Swarm simulation outputs
simulations/
swarm_logs/
swarm_data/
swarm_outputs/

# Agent state files
agent_states/
*.agent_state
*.swarm_state

# Communication logs
communication_logs/
message_logs/

# Experiment results
results/
experiments_results/
evaluation_results/
benchmark_results/

# Visualization outputs
visualizations/
plots/
figures/
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.pdf

# Configuration overrides (keep examples)
config/local_*.yaml
config/local_*.yml
config/private_*.yaml
config/private_*.yml
!config/example_*.yaml
!config/example_*.yml

# Generated documentation
docs/generated/
docs/_build/

# Temporary swarm data
tmp_swarm/
temp_swarm/
*.swarm_tmp

# Performance benchmarks
benchmarks/data/
benchmarks/results/

# =============================================================================
# IDE PATTERNS
# =============================================================================

# VS Code
.vscode/
*.code-workspace
.history/

# PyCharm / IntelliJ
.idea/
*.iml
*.iws
*.ipr
out/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Atom
.atom/

# Eclipse
.project
.classpath
.settings/

# NetBeans
nbproject/

# Vim
*.swp
*.swo
*~
.vim/

# Emacs
*~
#*#
.#*

# =============================================================================
# OS PATTERNS
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?
Icon\r

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.nfs*
.directory
.Trash-*

# =============================================================================
# MISC PATTERNS
# =============================================================================

# Temporary files
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
*.old
*.orig

# Archives
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z

# Secrets and credentials
*.pem
*.key
*.crt
*.csr
secrets.yaml
secrets.yml
secrets.json
credentials.yaml
credentials.yml
credentials.json
*.secret

# Docker
.dockerignore
docker-compose.override.yml

# Kubernetes
*.kubeconfig

# Terraform
.terraform/
*.tfstate
*.tfstate.*

# Local development overrides
local_settings.py
local_config.py

# Profiling data
*.prof
*.lprof
profile/

# Core dumps
core
core.*
*.core

# Lock files
*.lock
Pipfile.lock
poetry.lock
!poetry.lock  # Uncomment if you want to track poetry.lock

# Node (if using any JS tooling)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
